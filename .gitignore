# Create .gitignore file
cat > .gitignore << 'EOF'
# Laravel specific
/vendor/
node_modules/
.env
.env.example
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
storage/*.key
/.idea
/.vscode

# Laravel logs
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*

# IDE helpers
_ide_helper.php
.phpstorm.meta.php

# Composer
composer.phar
/composer.lock

# PHPUnit
/phpunit.xml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Project specific
public/uploads/*
!.gitkeep
EOF